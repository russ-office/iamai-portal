{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/pulse/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|JetBrains Mono|Lora))/i]",
        "message": "Font not provided by the design system. Available: Manrope, JetBrains Mono, Lora."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityFeed'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|days|style|key|ref|className|style|children)$/]",
        "message": "<ActivityFeed> doesn't accept that prop. Declared props: data, days, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|quiet)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|primary|secondary|meta|trailing|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DataRow> doesn't accept that prop. Declared props: status, primary, secondary, meta, trailing, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:bad|warn|ok|none)$/]",
        "message": "<DataRow> status must be one of 'bad' | 'warn' | 'ok' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Drawer'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|eyebrow|children|footer|formSrc|width|key|ref|className|style|children)$/]",
        "message": "<Drawer> doesn't accept that prop. Declared props: open, onClose, title, eyebrow, children, footer, formSrc, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='Empty'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|style|key|ref|className|style|children)$/]",
        "message": "<Empty> doesn't accept that prop. Declared props: children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Indicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|size|style|key|ref|className|style|children)$/]",
        "message": "<Indicator> doesn't accept that prop. Declared props: status, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Indicator'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:bad|warn|ok|none)$/]",
        "message": "<Indicator> status must be one of 'bad' | 'warn' | 'ok' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|className|style|key|ref|className|style|children)$/]",
        "message": "<KpiTile> doesn't accept that prop. Declared props: value, label, sub, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|className|style|key|ref|className|style|children)$/]",
        "message": "<Metric> doesn't accept that prop. Declared props: value, label, sub, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RankRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:position|name|status|value|className|style|key|ref|className|style|children)$/]",
        "message": "<RankRow> doesn't accept that prop. Declared props: position, name, status, value, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RankRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:bad|warn|ok|none)$/]",
        "message": "<RankRow> status must be one of 'bad' | 'warn' | 'ok' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|meta|complete|className|style|key|ref|className|style|children)$/]",
        "message": "<StageBar> doesn't accept that prop. Declared props: label, value, meta, complete, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Triad'] > JSXAttribute > JSXIdentifier[name!=/^(?:problem|output|input|heads|className|style|key|ref|className|style|children)$/]",
        "message": "<Triad> doesn't accept that prop. Declared props: problem, output, input, heads, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
